// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  category       String          @unique
  dvds           Dvd[]
  audioBooks     AudioBook[]
  books          Book[]
  referenceBooks ReferenceBook[]
}

model Dvd {
  title          String   @unique
  runTimeMinutes Int
  type           String
  isBorrowable   Boolean
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [category])
}

model AudioBook {
  title          String   @unique
  runTimeMinutes Int
  type           String
  isBorrowable   Boolean
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [category])
}

model Book {
  title        String   @unique
  author       String
  nbrPages     Int
  type         String
  isBorrowable Boolean
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [category])
}

model ReferenceBook {
  title        String   @unique
  author       String
  nbrPages     Int
  type         String
  isBorrowable Boolean
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [category])
}
